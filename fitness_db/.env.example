# Postgres connection for migrate.sh / app connections
# Provide either DATABASE_URL (preferred) or standard PG* variables.
#
# IMPORTANT: The backend container (fitness_backend_api) should use the same DATABASE_URL
# so both the app and migrations point at the same database.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fitness

# Alternatively (psql/libpq):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=fitness
